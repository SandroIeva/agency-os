# Public env vars exposed to the browser (Vite). Set the same values in Vercel project settings.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Picker — required for the "Aus Drive wählen" button in the Files view.
# Create the API key in Google Cloud Console → APIs & Services → Credentials → "+ Create credentials" → "API key".
# Then restrict it to: APIs = "Google Picker API" (enable that API first under APIs & Services → Library).
VITE_GOOGLE_API_KEY=

# Optional: Google Cloud project number. Helps the Picker show "shared with me" sources correctly.
# Find it in Cloud Console → top-left project switcher → number under the project name.
VITE_GOOGLE_APP_ID=

# Server-only billing configuration. Never prefix these values with VITE_ and
# never expose them in browser code. Add them to Vercel for Preview and Production.
PUBLIC_APP_URL=https://app.i7os.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=
# Legacy projects can use SUPABASE_ANON_KEY instead of SUPABASE_PUBLISHABLE_KEY.
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
# Legacy projects can use SUPABASE_SERVICE_ROLE_KEY instead of SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_ANNUAL=
