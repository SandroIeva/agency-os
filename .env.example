# Public env vars exposed to the browser (Vite). Set the same values in Vercel project settings.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Picker — required for the "Aus Drive wählen" button in the Files view.
# Create the API key in Google Cloud Console → APIs & Services → Credentials → "+ Create credentials" → "API key".
# Then restrict it to: APIs = "Google Picker API" (enable that API first under APIs & Services → Library).
VITE_GOOGLE_API_KEY=

# Optional: Google Cloud project number. Helps the Picker show "shared with me" sources correctly.
# Find it in Cloud Console → top-left project switcher → number under the project name.
VITE_GOOGLE_APP_ID=
